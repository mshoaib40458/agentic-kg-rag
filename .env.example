# =============================================================
# KG-RAG Enterprise Assistant — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# =============================================================

# ── LLM Provider ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Model Config ─────────────────────────────────────────
LLM_QUERY_MODEL=llama-3.3-70b-versatile
LLM_INGEST_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# ── Embedding Config ──────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Neo4j Knowledge Graph ─────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# ── FAISS Vector Store ────────────────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
FAISS_METADATA_PATH=data/faiss_metadata.json

# ── Redis Cache ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600

# ── FastAPI Server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Security / Auth ───────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_long_random_secret_key_minimum_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── Default Admin User (created on first run) ─────────────────
ADMIN_USERNAME=admin
# REQUIRED: Set a strong password before first start (minimum 16 characters)
# The server will refuse to start if this is not set or uses a weak value.
ADMIN_PASSWORD=CHANGEME_set_strong_password_16plus_chars

# ── Audit Logging ─────────────────────────────────────────────
AUDIT_LOG_PATH=logs/audit.jsonl
LOG_LEVEL=INFO

# ── Ingestion Config ──────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_UPLOAD_SIZE_MB=50
DOCUMENTS_PATH=data/documents

# ── Retrieval Config ──────────────────────────────────────────
VECTOR_TOP_K=10
GRAPH_HOP_DEPTH=3
RERANK_TOP_K=5

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Hybrid Retrieval Weights ──────────────────────────────────
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_GRAPH_WEIGHT=0.4
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
